AWS_REGION=us-east-1
STACK_NAME=cortexcc
INSTANCE_TYPE=t3.large
AMI_ID=ami-xxxxxxxxxxxxxxxxx
KEY_NAME=cortexcc-key

# Repository and branch to deploy on EC2
GIT_URL=https://github.com/tu-org/cortexcc.git
GIT_REF=main

# After EC2 launch, REPLACE_PUBLIC_IP (or PUBLIC_IP) in URL vars below is replaced automatically
# Set true only for demo/staging (loads users from prisma/seed.ts)
RUN_PRISMA_SEED=false

# Backend runtime values (port must remain 3030)
BACKEND_PORT=3030
API_PREFIX=/api
CORS_ORIGIN=http://REPLACE_PUBLIC_IP:8080
DATABASE_URL=postgresql://USER:PASSWORD@RDS_HOST:5432/cortexcc
MASTER_DATABASE_URL=postgresql://USER:PASSWORD@RDS_HOST:5432/cortexcc_master
# Primera instalación: RUN_SETUP_MASTER=true registra tenant local en Master (requiere DATABASE_URL del tenant)
RUN_SETUP_MASTER=false
REDIS_URL=redis://REDIS_HOST:6379/2
QUEUE_CONCURRENCY=5
ENABLE_JOBS=true
SOCKETIO_PATH=/socket.io
SOCKETIO_CORS_ORIGIN=http://REPLACE_PUBLIC_IP:8080
JWT_SECRET=CHANGE_ME_MIN_32
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
INTEGRATION_API_KEY=CHANGE_ME
AGENTHUB_PUBLIC_URL=http://REPLACE_PUBLIC_IP:3100
CORTEX_CC_API_BASE_URL=http://REPLACE_PUBLIC_IP:3030
BUSINESS_TIMEZONE=America/Guayaquil
STORAGE_PROVIDER=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attachments
CHANNEL_CONFIG_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
PRISMA_LOG_QUERIES=false

# Frontend runtime values (port must remain 8080)
FRONTEND_PORT=8080
VITE_API_URL=http://REPLACE_PUBLIC_IP:3030/api
VITE_WS_URL=http://REPLACE_PUBLIC_IP:3030
VITE_SOCKET_PATH=/socket.io
