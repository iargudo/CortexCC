# Copiar a deploy/azure/.env y completar valores reales (no commitear .env)

# --- Recursos Azure ---
RESOURCE_GROUP=rg-cortexcc-stg-001
LOCATION=canadacentral
APP_SERVICE_PLAN=plan-cortexcc-stg-001
BACKEND_WEBAPP_NAME=app-back-cortexcc-stg-001
FRONTEND_WEBAPP_NAME=app-front-cortexcc-stg-001
ACR_NAME=acrcortexccstg001
APP_SERVICE_SKU=B1
# Placeholder al crear Web App (el contenedor Docker usa Node 20). En tu suscripcion: NODE:22-lts o NODE:24-lts
AZURE_WEBAPP_RUNTIME=NODE:22-lts

# Azure Cache for Redis (el script lo crea si MANAGE_REDIS=true)
REDIS_NAME=redis-cortexcc-stg-001
REDIS_SKU=Basic
REDIS_VM_SIZE=c0
REDIS_DB=2
MANAGE_REDIS=true
SKIP_REDIS_CREATE=false

# Puertos fijos del proyecto (no cambiar)
BACKEND_PORT=3030
FRONTEND_PORT=8080
API_PREFIX=/api

# Dejar vacio para generar JWT aleatorios en cada deploy
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Postgres tenant (BD de negocio; usada por scripts seed/migrate-tenant)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/cortexcontact?sslmode=require

# Postgres Master (registro de tenants)
MASTER_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/cortexcc_master?sslmode=require
RUN_SETUP_MASTER=false

# Redis: dejar vacio si MANAGE_REDIS=true (se genera rediss://... al desplegar)
# Si MANAGE_REDIS=false, define REDIS_URL manualmente
REDIS_URL=

QUEUE_CONCURRENCY=5
ENABLE_JOBS=true
SOCKETIO_PATH=/socket.io
INTEGRATION_API_KEY=CHANGE_ME_MIN_8_CHARS
BUSINESS_TIMEZONE=America/Guayaquil
PRISMA_LOG_QUERIES=false

# Solo demo/staging
RUN_PRISMA_SEED=false

# Opcionales (backend .env.example)
AGENTHUB_PUBLIC_URL=
CORTEX_CC_API_BASE_URL=
STORAGE_PROVIDER=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attachments
CHANNEL_CONFIG_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# --- Asterisk PBX (RG dedicado — deploy/azure/deploy-azure-asterisk-vm.sh) ---
# Debe alinearse con el entorno de CortexCC (mismo sufijo stg/prd-001)
ASTERISK_RESOURCE_GROUP=rg-cortexcc-pbx-stg-001
ASTERISK_VM_NAME=vm-asterisk-cortexcc-stg-001
ASTERISK_PUBLIC_IP_NAME=pip-asterisk-cortexcc-stg-001
ASTERISK_NSG_NAME=nsg-asterisk-cortexcc-stg-001
ASTERISK_NIC_NAME=nic-asterisk-cortexcc-stg-001
ASTERISK_VNET_NAME=vnet-asterisk-cortexcc-stg-001
ASTERISK_SUBNET_NAME=snet-asterisk-cortexcc-stg-001
ASTERISK_VM_SIZE=Standard_B2s
ASTERISK_ADMIN_USER=azureuser
# Opcional: FQDN público (pbx.empresa.com). Si vacío, usa IP pública.
ASTERISK_FQDN=
MANAGE_ASTERISK_VM=true
INTEGRATE_CORTEXCC=true
ASTERISK_RESTRICT_ARI_TO_BACKEND=true
CREATE_VOICE_CHANNEL=true
VOICE_CHANNEL_NAME=Telefonía PBX
# JWT admin (permiso settings) para crear/actualizar canal VOICE vía API. Vacío = solo App Settings + manual UI.
CORTEXCC_DEPLOY_JWT=
ASTERISK_ARI_APP=cortexcc
ASTERISK_ARI_USERNAME=cortexcc
ASTERISK_ARI_PASSWORD=Admin123!
ASTERISK_SIP_PORT=5060
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10100
ASTERISK_ARI_PUBLIC_PORT=8074
ASTERISK_WSS_PORT=8089
ASTERISK_TZ=America/Guayaquil
# Trunk saliente (opcional; se escribe en .env de la VM)
TRUNK_HOST=sip.carrier.example.com
TRUNK_USER=
TRUNK_PASS=
