# Plantilla staging — copiar a deploy/azure/config/cortexcc.stg
# Deploy: ./deploy/azure/cortexcc/deploy-cortexcc.sh stg

CORTEXCC_ENV=stg

# --- Recursos Azure ---
RESOURCE_GROUP=rg-cortexcc-stg-001
LOCATION=canadacentral
APP_SERVICE_PLAN=plan-cortexcc-stg-001
BACKEND_WEBAPP_NAME=app-back-cortexcc-stg-001
FRONTEND_WEBAPP_NAME=app-front-cortexcc-stg-001
ACR_NAME=acrcortexccstg001
APP_SERVICE_SKU=B1
AZURE_WEBAPP_RUNTIME=NODE:22-lts

# Azure Cache for Redis (el script lo crea si MANAGE_REDIS=true)
REDIS_NAME=redis-cortexcc-stg-001
REDIS_SKU=Basic
REDIS_VM_SIZE=c0
REDIS_DB=2
MANAGE_REDIS=true
SKIP_REDIS_CREATE=false

# Puertos fijos del proyecto (no cambiar)
BACKEND_PORT=3030
FRONTEND_PORT=8080
API_PREFIX=/api

# Staging: pueden generarse en cada deploy si se dejan vacios
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Postgres tenant — comillas obligatorias si la URL contiene &
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cortexcontact?sslmode=require"

# Postgres Master (registro de tenants)
MASTER_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cortexcc_master?sslmode=require"
RUN_SETUP_MASTER=false
RUN_SETUP_PLATFORM_ADMIN=false
BOOTSTRAP_TENANT=false
# RUN_SETUP_MASTER=true
# RUN_SETUP_PLATFORM_ADMIN=true
# PLATFORM_ADMIN_EMAIL=platform@empresa.com
# PLATFORM_ADMIN_PASSWORD=CAMBIAR_PASSWORD
# BOOTSTRAP_TENANT=true
# TENANT_KEY=demo
# TENANT_NAME="Demo Staging"
# TENANT_SEED=true

# Redis: dejar vacio si MANAGE_REDIS=true (se genera rediss://... al desplegar)
REDIS_URL=

QUEUE_CONCURRENCY=5
ENABLE_JOBS=true
SOCKETIO_PATH=/socket.io
INTEGRATION_API_KEY=CHANGE_ME_MIN_8_CHARS
PRISMA_LOG_QUERIES=false

RUN_PRISMA_SEED=false

STORAGE_PROVIDER=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attachments
