# Plantilla staging — copiar a deploy/azure/config/asterisk.stg
# Deploy: ./deploy/azure/asterisk/deploy-asterisk-vm.sh stg
# Requiere deploy/azure/config/cortexcc.stg del mismo ambiente

ASTERISK_RESOURCE_GROUP=rg-cortexcc-pbx-stg-001
ASTERISK_VM_NAME=vm-asterisk-cortexcc-stg-001
ASTERISK_PUBLIC_IP_NAME=pip-asterisk-cortexcc-stg-001
ASTERISK_NSG_NAME=nsg-asterisk-cortexcc-stg-001
ASTERISK_NIC_NAME=nic-asterisk-cortexcc-stg-001
ASTERISK_VNET_NAME=vnet-asterisk-cortexcc-stg-001
ASTERISK_SUBNET_NAME=snet-asterisk-cortexcc-stg-001
ASTERISK_VM_SIZE=Standard_B2s
ASTERISK_ADMIN_USER=azureuser
ASTERISK_FQDN=
MANAGE_ASTERISK_VM=true
INTEGRATE_CORTEXCC=true
ASTERISK_RESTRICT_ARI_TO_BACKEND=true
CREATE_VOICE_CHANNEL=true
VOICE_CHANNEL_NAME=Telefonía PBX
CORTEXCC_DEPLOY_JWT=
ASTERISK_ARI_APP=cortexcc
ASTERISK_ARI_USERNAME=cortexcc
ASTERISK_ARI_PASSWORD=Admin123!
ASTERISK_SIP_PORT=5060
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10100
ASTERISK_ARI_PUBLIC_PORT=8074
ASTERISK_WSS_PORT=8089
ASTERISK_TZ=America/Guayaquil
TRUNK_HOST=sip.carrier.example.com
TRUNK_USER=
TRUNK_PASS=
