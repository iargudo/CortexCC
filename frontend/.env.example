# ── Desarrollo en localhost (misma máquina) ──
VITE_TENANT_KEY=local
VITE_TENANT_NAME=Desarrollo Local
VITE_API_URL=http://localhost:3030/api
VITE_WS_URL=http://localhost:3030

# ── Desarrollo en LAN (otra PC en la red) ──
# Un solo comando desde la raíz: ./scripts/set-lan-ip.sh
# Requiere HTTPS: Vite usa certificados de deploy/asterisk/keys/ y proxy /api → backend :3030
# VITE_TENANT_KEY no aplica al acceder por IP.
# VITE_API_URL=https://192.168.x.x:8080/api
# VITE_WS_URL=https://192.168.x.x:8080

# Path de Socket.IO (debe coincidir con SOCKETIO_PATH del backend)
VITE_SOCKET_PATH=/socket.io
