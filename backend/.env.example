NODE_ENV=development
# Activa logs SQL de Prisma (incluye SELECT) solo para depuración puntual
PRISMA_LOG_QUERIES=false
PORT=3030
API_PREFIX=/api
CORS_ORIGIN=http://localhost:8080

# PostgreSQL en la máquina local (ajusta usuario, contraseña, host y puerto a tu instalación)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/cortexcontact

JWT_SECRET=change-me-min-32-characters-long-secret!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-secret!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis en la máquina local (puerto por defecto 6379; el sufijo /2 es el número de base de datos lógica)
REDIS_URL=redis://localhost:6379/2
QUEUE_CONCURRENCY=5
ENABLE_JOBS=true

SOCKETIO_PATH=/socket.io
SOCKETIO_CORS_ORIGIN=http://localhost:8080

# Clave compartida para integraciones externas en x-api-key (POST .../integrations/escalate)
INTEGRATION_API_KEY=dev-integration-api-key-change-me

# ── CortexAgentHub (desarrollo) ──
# Backend de AgentHub (host/puerto local o staging).
AGENTHUB_PUBLIC_URL=http://localhost:3100
# Este API (Cortex CC); úsalo en AgentHub como CORTEX_CC_API_BASE_URL en la tool de escalamiento.
CORTEX_CC_API_BASE_URL=http://localhost:3030

BUSINESS_TIMEZONE=America/Guayaquil

STORAGE_PROVIDER=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attachments

CHANNEL_CONFIG_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
